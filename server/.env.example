DATABASE_URL="postgresql://postgres:postgres@localhost:5432/xaxamax?schema=public"
JWT_SECRET="your-jwt-secret-change-me"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-change-me"
PORT=3001
CLIENT_URL="http://localhost:5173"
UPLOAD_DIR="uploads"
TMDB_API_KEY=""
TMDB_LANGUAGE="ru-RU"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_API_MAX=300
RATE_LIMIT_AUTH_MAX=20

# Web Push VAPID keys (generate with: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k)")
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_CONTACT="admin@xaxamax.app"
